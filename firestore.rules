rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == "geanpratama@gmail.com"; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Helper to check if the document belongs to the signed-in user
    function isDocOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    // Pillar 2: Validation Blueprints
    function isValidUser(data) {
      return data.userId == request.auth.uid || isAdmin();
    }

    function isValidContentPlan(data) {
      return data.userId == request.auth.uid || isAdmin();
    }

    function isValidScheduledPost(data) {
      return data.userId == request.auth.uid || isAdmin();
    }

    function isValidChatSession(data) {
      return data.userId == request.auth.uid || isAdmin();
    }

    function isValidMonitoringEntry(data) {
      return data.userId == request.auth.uid || isAdmin();
    }

    function isValidMonthlyPlan(data) {
      // plan is mandatory
      return data.plan is string;
    }

    function isValidStockFootage(data) {
      return data.userId == request.auth.uid || isAdmin();
    }

    function isValidManagedAccount(data) {
      return data.userId == request.auth.uid || isAdmin();
    }

    // Pillar 4: Tiered Identity Logic & Pillar 10: Timestamps
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(incoming());
      allow list: if isAdmin();

      match /monthlyPlans/{periodId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /stockFootage/{footageId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && (incoming().userId == request.auth.uid) && isValidStockFootage(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /contentPlans/{planId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && (incoming().userId == request.auth.uid) && isValidContentPlan(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /scheduledPosts/{postId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && (incoming().userId == request.auth.uid) && isValidScheduledPost(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /chatSessions/{sessionId} {
      allow get: if isOwner(sessionId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isOwner(sessionId) && isValidChatSession(incoming());
      allow delete: if isOwner(sessionId);
    }

    match /monitoringEntries/{entryId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid) && isValidMonitoringEntry(incoming());
      allow delete: if isDocOwner(existing()) || isAdmin();
    }

    match /managedAccounts/{accountId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid && isValidManagedAccount(incoming()));
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /whitelistedUsers/{whiteId} {
      allow list: if true; 
      allow get: if true; 
      allow create, update, delete: if isAdmin();
    }
  }
}
